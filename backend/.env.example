# Copy this to .env and fill in your values
PORT=5000
NODE_ENV=production

# MongoDB Atlas — Required for all form saves
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/quantumai?retryWrites=true&w=majority

# Allowed Origins (comma-separated — add your production domain here)
# Example: https://www.quantumai.in,https://quantumai.in
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
